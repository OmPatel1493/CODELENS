# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

APP_NAME="CodeLens API"
ENVIRONMENT=development
DEBUG=true

# SQLite for local dev. For production, set an Azure PostgreSQL URL, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/codelens
DATABASE_URL=sqlite:///./codelens.db

# Comma-separated in real env vars; the Vite dev server default is below.
CORS_ORIGINS=["http://localhost:5173"]

# --- Auth / JWT ---
# Generate a strong secret for production: `openssl rand -hex 32`
JWT_SECRET_KEY=change-me-to-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Storage ---
# "local" = filesystem (free, offline — the dev default). "s3" = AWS S3 / MinIO.
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./data/storage

# Only needed when STORAGE_BACKEND=s3:
S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Set for S3-compatible stores like MinIO (e.g. http://localhost:9000); blank = AWS.
S3_ENDPOINT_URL=

# Reject repository archives larger than this many bytes (default 50 MB).
MAX_ARCHIVE_BYTES=52428800

# --- Embeddings / vector index ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_DIR=./data/chroma
MAX_FILE_BYTES=1048576
