# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

APP_NAME="CodeLens API"
ENVIRONMENT=development
DEBUG=true

# SQLite for local dev. For production (Render), set a Postgres URL, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/codelens
DATABASE_URL=sqlite:///./codelens.db

# Comma-separated in real env vars; the Vite dev server default is below.
CORS_ORIGINS=["http://localhost:5173"]

# --- Auth / JWT ---
# Generate a strong secret for production: `openssl rand -hex 32`
JWT_SECRET_KEY=change-me-to-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
